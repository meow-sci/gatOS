#!/bin/sh
# gatOS guest early init (busybox ::sysinit). Every step is best-effort so a
# single failure can never keep dropbear (the only way in) from starting.
export PATH=/usr/sbin:/usr/bin:/sbin:/bin

# Kernel filesystems. devtmpfs is normally mounted already (initramfs hands it over).
mount -t proc -o nodev,nosuid,noexec proc /proc 2>/dev/null
mount -t sysfs -o nodev,nosuid,noexec sysfs /sys 2>/dev/null
mount -t devtmpfs devtmpfs /dev 2>/dev/null
mkdir -p /dev/pts /dev/shm
mount -t devpts -o gid=5,mode=620 devpts /dev/pts 2>/dev/null
mount -t tmpfs -o nodev,nosuid tmpfs /dev/shm 2>/dev/null
mount -t tmpfs tmpfs /run 2>/dev/null
mount -t tmpfs tmpfs /tmp 2>/dev/null

mount -o remount,rw / 2>/dev/null

# Grow the root filesystem to fill the block device. The host sizes the per-save overlay from
# the gatOS [disk_size_gb] config (grow-only); resize2fs expands the ext4 online to match. The
# root mount already created /dev/vda. No-op (exit 0) once the fs already fills the device.
resize2fs /dev/vda 2>/dev/null

# Device nodes + drivers for the fixed QEMU hardware (q35 + virtio-net + virtio-serial).
mdev -s 2>/dev/null
modprobe -a virtio_net virtio_console 2>/dev/null

# /dev/virtio-ports/<name> symlinks — mdev creates only /dev/vportNpM; qemu-ga
# wants the stable by-name path (udev would normally provide it).
for d in /sys/class/virtio-ports/vport*; do
    [ -f "$d/name" ] || continue
    mkdir -p /dev/virtio-ports
    ln -sf "/dev/${d##*/}" "/dev/virtio-ports/$(cat "$d/name")"
done

hostname -F /etc/hostname 2>/dev/null

# Static slirp network — no DHCP (faster + deterministic; QEMU user-mode net only:
# guest is always 10.0.2.15, host gateway 10.0.2.2, DNS 10.0.2.3).
ifconfig lo up 2>/dev/null
ifconfig eth0 10.0.2.15 netmask 255.255.255.0 up 2>/dev/null
route add default gw 10.0.2.2 2>/dev/null

mkdir -p /sim

# Magic HTTP transport (G5): the host advertises its server port as gatos.httpport=<port> on
# the kernel cmdline (0/absent = disabled). The guest reaches the host server outbound at
# 10.0.2.2 (slirp); /etc/hosts aliases that to 'sim'. Login shells pick up $GATOS_HTTP via
# /etc/profile.d, and /run/gatos/http-port carries the bare port for non-shell consumers.
HTTP_PORT="$(sed -n 's/.*gatos\.httpport=\([0-9][0-9]*\).*/\1/p' /proc/cmdline)"
mkdir -p /run/gatos /etc/profile.d
MQTT_PORT="$(sed -n 's/.*gatos\.mqttport=\([0-9][0-9]*\).*/\1/p' /proc/cmdline)"
: > /etc/profile.d/gatos.sh
if [ -n "$HTTP_PORT" ] && [ "$HTTP_PORT" != "0" ]; then
    echo "$HTTP_PORT" > /run/gatos/http-port
    printf 'export GATOS_HTTP="http://sim:%s/v1"\n' "$HTTP_PORT" >> /etc/profile.d/gatos.sh
else
    rm -f /run/gatos/http-port 2>/dev/null
fi
if [ -n "$MQTT_PORT" ] && [ "$MQTT_PORT" != "0" ]; then
    echo "$MQTT_PORT" > /run/gatos/mqtt-port
    # MQTT has no URL scheme convention; export host + port (broker is at 'sim' = 10.0.2.2).
    printf 'export GATOS_MQTT="sim:%s"\n' "$MQTT_PORT" >> /etc/profile.d/gatos.sh
else
    rm -f /run/gatos/mqtt-port 2>/dev/null
fi

# G7 serial bus: the host wires a 'gatos.serial' virtio-serial port (chardev), which the vport
# loop above symlinks to /dev/virtio-ports/gatos.serial. Unlike HTTP/MQTT there is no port to
# advertise (it is a local device, not a slirp server) — just point $GATOS_SERIAL at it when the
# host enabled it. `cat` the device for telemetry; `echo CTL:... >` it to send SCPI commands.
if [ -e /dev/virtio-ports/gatos.serial ]; then
    printf 'export GATOS_SERIAL="/dev/virtio-ports/gatos.serial"\n' >> /etc/profile.d/gatos.sh
fi
